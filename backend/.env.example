# Ключ Groq — используется бэкендом напрямую, в браузер НЕ уходит.
# Получить бесплатно: https://console.groq.com/
# Положи свой ключ в backend/.env (этот файл — шаблон)
# ⚠️ В ЭТОМ ФАЙЛЕ НЕ ДОЛЖНО БЫТЬ РЕАЛЬНОГО КЛЮЧА — он попадёт в публичный Git-репо
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# Порт бэкенда (по умолчанию 8000)
PORT=8000
